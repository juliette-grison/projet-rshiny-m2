parse_colonne <- function(x) {
if (is.na(x) || trimws(x) == "") return(character(0))
# Si format c("...", "...") — extraire les chaînes entre guillemets
if (grepl('^c\\(', trimws(x))) {
matches <- regmatches(x, gregexpr('"([^"]*)"', x))[[1]]
valeurs <- gsub('^"|"$', '', matches)
} else {
valeurs <- x
}
# Nettoyer : retirer les vides et les espaces
valeurs <- trimws(valeurs)
valeurs <- valeurs[valeurs != ""]
return(valeurs)
}
html_liste <- function(x) {
items <- parse_colonne(x)
if (length(items) == 0) {
return("<span style='color:#aaa; font-style:italic;'>Information non disponible</span>")
}
items_html <- paste0(
"<li style='margin-bottom:3px;'>", items, "</li>",
collapse = ""
)
paste0(
"<ul style='margin:4px 0 0 0; padding-left:16px; color:#333;'>",
items_html,
"</ul>"
)
}
runApp()
