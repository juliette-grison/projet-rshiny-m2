})
renderLeaflet({
leaflet(data_hebergements) %>%
addTiles() %>%
# Zoom sur Île-de-France
setView(
lng = 2.35,   # Paris
lat = 48.85,
zoom = 10
) %>%
addCircleMarkers(
lng = ~Longitude,
lat = ~Latitude,
radius = 5,
color = "#071F32",
fillOpacity = 0.8,
# HOVER (label)
label = ~paste0(
"<b>Etablissement :</b> ", nom_etablissement, "<br>",
"<b>Adresse :</b> ", adresse, "<br>",
"<b>Code Postal :</b> ", code_postal, "<br>",
"<b>Ville :</b> ", ville
) %>% lapply(htmltools::HTML),
# POPUP (clic)
popup = ~paste0(
"<div style='font-family: Montserrat;'>",
"<b>", nom_etablissement, "</b><br>",
adresse, "<br>",
code_postal, " ", ville,
"</div>"
)
)
})
